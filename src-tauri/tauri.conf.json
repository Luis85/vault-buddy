{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault Buddy",
  "version": "0.4.0",
  "identifier": "com.vaultbuddy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vault Buddy",
        "width": 88,
        "height": 88,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "panel",
        "title": "Vault Buddy Panel",
        "width": 360,
        "height": 340,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "bubble",
        "title": "Vault Buddy Greeting",
        "width": 260,
        "height": 150,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFMjZBRjZFMEZFOEY4NUYKUldSZitPZ1BicThtcnBKM1FFRjNiY1lVQlJYZHROc2g4anQ0cHNsbW9mUFJ0anh4L0hWR2V5c3oK",
      "endpoints": [
        "https://github.com/Luis85/vault-buddy/releases/latest/download/latest.json"
      ]
    }
  }
}
