    "quality:audit": "fallow audit",
    "tauri": "tauri",
    "test-build": "tauri dev",
    "bump-version": "node scripts/bump-version.mjs",
    "setup:linux": "bash scripts/setup-linux-deps.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "pinia": "^3",
    "vue": "^3.5"
  },
  "overrides": {
    "js-beautify": {
      "glob": "^13"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.22",
    "@vue/test-utils": "^2",
    "eslint": "^10.6.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "fallow": "^3.3.0",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
